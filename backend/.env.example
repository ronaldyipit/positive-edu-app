POE_API_KEY=your_poe_api_key_here
# 感恩卡內文與插圖皆使用上方 POE_API_KEY（Poe 內建 DALL-E），不需另設 OPENAI_API_KEY。
PORT=4000

# ── OTP 電郵驗證 ──
OTP_SECRET=put-a-random-string-here
# Gmail SMTP：先開啟 Google 帳號的兩步驟驗證，再到 https://myaccount.google.com/apppasswords 產生應用程式密碼
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# ── Firebase Admin（重設密碼用） ──
# 取得方式：Firebase Console → 專案設定 → 服務帳戶 → 產生新的私密金鑰 → 下載 JSON
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
