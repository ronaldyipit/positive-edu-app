# Firebase（登入／註冊用）。複製為 .env 並填入實際值。
# 取得方式：Firebase Console → 專案設定 → 一般 → 您的應用程式 → 設定
EXPO_PUBLIC_FIREBASE_API_KEY=

# 正向教練 API（可選）。未設定時預設為 http://localhost:4000（本機後端）
# 若用手機／另一台電腦連到本機後端，可設為電腦的 LAN IP，例如：http://192.168.68.120:4000
# EXPO_PUBLIC_COACH_API_URL=http://localhost:4000
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
