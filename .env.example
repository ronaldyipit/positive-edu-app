# Firebase（登入／註冊用）。複製為 .env 並填入實際值。
# 取得方式：Firebase Console → 專案設定 → 一般 → 您的應用程式 → 設定
# 重要：Firebase Console → 建構 → Authentication → 登入方法 → 啟用「電子郵件/密碼」與「Google」
EXPO_PUBLIC_FIREBASE_API_KEY=

# 正向教練 API（可選）。未設定時預設為 http://localhost:4000（本機後端）
# 若用手機／另一台電腦連到本機後端，可設為電腦的 LAN IP，例如：http://192.168.68.120:4000
# EXPO_PUBLIC_COACH_API_URL=http://localhost:4000
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google 登入（OAuth）。取得方式見下方。
# Web：Google Cloud Console → 憑證 → 類型「Web 應用程式」→ 用戶端 ID。
# 只要填好 Web 用戶端 ID，Expo Go 即可用 Google 登入；Android / iOS 可留空，App 會自動用 Web 的 ID。
# 若手機 Expo Go 出現 400 invalid_request 或 redirect_uri 錯誤，請填下面這行，
# 並在 Google Console「已授權的重新導向 URI」加入該網址。
# 取得方式：在專案目錄執行 npx expo start 後，在終端或 App 內看 redirect URL；或使用 https://auth.expo.io/@你的Expo帳號/positive-edu-app
# EXPO_PUBLIC_EXPO_AUTH_REDIRECT_URI=https://auth.expo.io/@你的Expo帳號/positive-edu-app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android（可選）：僅在 build 正式 APK 且要單獨用 Android OAuth 時才填。留空則使用上方 Web ID。
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS（可選）：僅在 build 正式 iOS 且要單獨用 iOS OAuth 時才填。留空則使用上方 Web ID。
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
